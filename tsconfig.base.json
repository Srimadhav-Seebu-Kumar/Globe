{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@globe/config": ["packages/config/src/index.ts"],
      "@globe/geo": ["packages/geo/src/index.ts"],
      "@globe/types": ["packages/types/src/index.ts"],
      "@globe/ui": ["packages/ui/src/index.tsx"]
    }
  }
}
